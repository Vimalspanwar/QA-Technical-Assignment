                "exec": [
                  "//checking the status code\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "// Test 2: Response time is acceptable\r",
                  "pm.test(\"Response time is under 10 seconds\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);\r",
                  "});\r",
                  "//Test 3: Response has candidates array\r",
                  "pm.test(\"Response has candidates array\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"candidates\");\r",
                  "    pm.expect(json.candidates).to.be.an(\"array\");\r",
                  "    pm.expect(json.candidates.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "// Test 4: Response contains actual text content\r",
                  "pm.test(\"Response contains text content\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    const text = json.candidates[0].content.parts[0].text;\r",
                  "    pm.expect(text).to.be.a(\"string\");\r",
                  "    pm.expect(text.length).to.be.above(50);\r",
                  "});\r",
                  "\r",
